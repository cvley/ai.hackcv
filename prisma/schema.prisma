// hackcv 正式持久化 · PostgreSQL 数据模型
// 运行方式：
//   npx prisma migrate dev --name init   # 创建/变更表结构
//   npx prisma db seed                  # 灌入种子数据
//   npx prisma studio                  # 可视化浏览数据
//   npx prisma generate               # 生成 Prisma Client

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 内容条目（论文 / 开源项目 / 行业资讯）
model Item {
  id            String   @id
  type          String // paper | project | news
  title         String
  titleZh       String?
  summary       String
  recommendation String?
  url           String   @unique
  permalink     String
  source        String
  sources       Json // string[]
  publishedAt   DateTime
  collectedAt   DateTime
  category      String
  tags          Json // string[]
  score         Int      @default(0)
  selected      Boolean  @default(true)
  dailyDate     String? // YYYY-MM-DD
  paperFields   Json?
  projectFields Json?
  newsFields    Json?
  videoFields   Json?
  interpretation Json? // 论文/代码解读：{ kind, summary, fields, generatedAt, provider }
  attribution   Json
  createdAt     DateTime
  updatedAt     DateTime

  @@index([type])
  @@index([category])
  @@index([publishedAt])
  @@index([selected])
  @@index([dailyDate])
  @@index([score])
}

// 信源（抓取来源，后台可启停/配置）
model Source {
  id            String   @id
  name          String
  type          String // rss | api | scraper | manual
  category      String // paper | project | news
  url           String
  enabled       Boolean  @default(true)
  lastFetch     DateTime?
  fetchInterval Int      @default(86400)

  @@index([enabled])
}

// 站点设置（单例行，id 固定为 1）
model SiteSetting {
  id                 Int    @id @default(1)
  siteName           String
  title              String
  description        String
  itemsPerDay        Int    @default(30)
  autoSelectThreshold Int   @default(55)
}

// LLM 调用的 token 消耗统计（每次采集按「日期 + 供应商」汇总一行）
model TokenUsage {
  id               String   @id @default(cuid())
  date             String // YYYY-MM-DD
  provider         String // 供应商 id（anthropic / siliconflow / deepseek …）
  promptTokens     Int      @default(0)
  completionTokens Int      @default(0)
  totalTokens      Int      @default(0)
  items            Int      @default(0) // 本次打分条目数
  createdAt        DateTime @default(now())

  @@index([date])
  @@index([provider])
}

// 更新日志（后台可编辑，按 version 倒序展示）
model Changelog {
  id        String   @id @default(cuid())
  version   String // 如 2026-07-12（同时作为日期 / 排序键）
  title     String
  items     Json // string[] 改动条目
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([version])
}

// 用户反馈（前台匿名提交，后台可见 / 标记处理）
model Feedback {
  id        String   @id @default(cuid())
  message   String // 反馈正文
  contact   String? // 邮箱 / 微信等联系方式（选填）
  page      String? // 提交来源页（location.pathname）
  status    String   @default("new") // new | read | resolved
  notified  Boolean  @default(false) // 是否已推送飞书每日摘要
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
  @@index([status])
  @@index([notified])
}
