# HMAC 图片代理签名密钥（生产务必修改）
HACKCV_IMG_SECRET=change-me-to-a-long-random-string

# 后台管理员会话签名密钥（生产务必修改）
HACKCV_ADMIN_SECRET=change-me-to-a-long-random-string

# 后台管理员账号（生产务必修改）
HACKCV_ADMIN_USER=admin
HACKCV_ADMIN_PASS=admin123

# PostgreSQL 连接串（Prisma 正式持久化，必填）
# 本地：brew install postgresql@16 后 createdb hackcv
DATABASE_URL=postgresql://hackcv:hackcv@localhost:5432/hackcv?schema=public

# ---- 真实 LLM 精选打分（可选；不配置则降级到启发式，免费可用）----
# 优先级：Anthropic → SiliconFlow 硅基流动 → OpenAI
# Anthropic（优先）：https://console.anthropic.com 获取
# ANTHROPIC_API_KEY=sk-ant-xxxx
# ANTHROPIC_MODEL=claude-3-5-haiku-latest
# SiliconFlow 硅基流动（OpenAI 兼容，中文友好、便宜）：https://cloud.siliconflow.cn 获取
# SILICONFLOW_API_KEY=sk-xxxx
# SILICONFLOW_MODEL=deepseek-ai/DeepSeek-V3
# DeepSeek（OpenAI 兼容）：https://platform.deepseek.com 获取
# DEEPSEEK_API_KEY=sk-xxxx
# DEEPSEEK_MODEL=deepseek-chat
# Moonshot Kimi（OpenAI 兼容）：https://platform.moonshot.cn 获取
# MOONSHOT_API_KEY=sk-xxxx
# MOONSHOT_MODEL=moonshot-v1-8k
# Zhipu GLM（OpenAI 兼容）：https://open.bigmodel.cn 获取
# ZHIPU_API_KEY=xxxx
# ZHIPU_MODEL=glm-4-flash
# Qwen 通义千问 DashScope（OpenAI 兼容）：https://dashscope.console.aliyun.com 获取
# DASHSCOPE_API_KEY=sk-xxxx
# DASHSCOPE_MODEL=qwen-plus
# OpenRouter（聚合，OpenAI 兼容）：https://openrouter.ai 获取
# OPENROUTER_API_KEY=sk-or-xxxx
# OPENROUTER_MODEL=openai/gpt-4o-mini
# OpenAI（备选）：https://platform.openai.com 获取
# OPENAI_API_KEY=sk-xxxx
# OPENAI_MODEL=gpt-4o-mini

# ---- 定时抓取调度密钥（可选；不配置则 /api/cron/ingest 禁用）----
# 部署后由 Vercel Cron / GitHub Actions / crontab 带上此密钥调用
# CRON_SECRET=一段随机长字符串
